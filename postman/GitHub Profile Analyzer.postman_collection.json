{
  "info": {
    "name": "GitHub Profile Analyzer",
    "description": "Complete API collection for the GitHub Profile Analyzer backend service.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            },
            "description": "Check if the API is running."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Analysis",
      "item": [
        {
          "name": "Analyze Profile — octocat",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/github/analyze/octocat",
              "host": ["{{baseUrl}}"],
              "path": ["api", "github", "analyze", "octocat"]
            },
            "description": "Fetch, analyze, and store the GitHub profile for 'octocat'."
          },
          "response": []
        },
        {
          "name": "Analyze Profile — torvalds",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/github/analyze/torvalds",
              "host": ["{{baseUrl}}"],
              "path": ["api", "github", "analyze", "torvalds"]
            },
            "description": "Fetch, analyze, and store the GitHub profile for 'torvalds'."
          },
          "response": []
        },
        {
          "name": "Analyze Profile — Invalid Username",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/github/analyze/--invalid!!",
              "host": ["{{baseUrl}}"],
              "path": ["api", "github", "analyze", "--invalid!!"]
            },
            "description": "Should return 400 for an invalid username."
          },
          "response": []
        },
        {
          "name": "Analyze Profile — Non-existent User",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/github/analyze/thisusercannotpossiblyexist999",
              "host": ["{{baseUrl}}"],
              "path": ["api", "github", "analyze", "thisusercannotpossiblyexist999"]
            },
            "description": "Should return 404 for a user that does not exist on GitHub."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Profiles",
      "item": [
        {
          "name": "Get All Profiles",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/github/profiles?page=1&limit=10&sortBy=analysis_score&sortOrder=desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "github", "profiles"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sortBy", "value": "analysis_score" },
                { "key": "sortOrder", "value": "desc" }
              ]
            },
            "description": "Fetch all analyzed profiles with pagination and sorting."
          },
          "response": []
        },
        {
          "name": "Get All Profiles — With Search",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/github/profiles?search=octo",
              "host": ["{{baseUrl}}"],
              "path": ["api", "github", "profiles"],
              "query": [
                { "key": "search", "value": "octo" }
              ]
            },
            "description": "Search profiles by username, name, location, or bio."
          },
          "response": []
        },
        {
          "name": "Get Single Profile — octocat",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/github/profiles/octocat",
              "host": ["{{baseUrl}}"],
              "path": ["api", "github", "profiles", "octocat"]
            },
            "description": "Fetch the analyzed profile for 'octocat'."
          },
          "response": []
        },
        {
          "name": "Get Single Profile — Not Found",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/github/profiles/unknownuser",
              "host": ["{{baseUrl}}"],
              "path": ["api", "github", "profiles", "unknownuser"]
            },
            "description": "Should return 404 if the profile has not been analyzed."
          },
          "response": []
        },
        {
          "name": "Delete Profile — octocat",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/github/profiles/octocat",
              "host": ["{{baseUrl}}"],
              "path": ["api", "github", "profiles", "octocat"]
            },
            "description": "Delete the analyzed profile for 'octocat'."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Statistics",
      "item": [
        {
          "name": "Get Aggregated Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/github/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "github", "stats"]
            },
            "description": "Returns aggregated statistics: total profiles, averages, top developers."
          },
          "response": []
        },
        {
          "name": "Get Leaderboard",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/github/leaderboard",
              "host": ["{{baseUrl}}"],
              "path": ["api", "github", "leaderboard"]
            },
            "description": "Returns top 10 developers ranked by analysis score."
          },
          "response": []
        }
      ]
    }
  ]
}
